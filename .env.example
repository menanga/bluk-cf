# Environment variables for bluk-cf

# Gmail IMAP credentials
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# 9Router API
NINE_ROUTER_PASSWORD=your_9router_password
NINE_ROUTER_URL=https://oapi.fastev.my.id/api

# Domains (comma-separated or newline-separated)
DOMAINS=forumbaris.com,menangatechnology.my.id,fastev.my.id,hamanstore.biz.id

# Batch processing settings
MAX_ACCOUNTS=10
BATCH_SIZE=5
DELAY_ACCOUNT=10
DELAY_BATCH=30
HEADLESS=true
